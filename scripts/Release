#!/usr/local/bin/java --source 21

import java.io.BufferedReader;
import java.io.IOException;
import java.io.InputStreamReader;
import java.nio.file.Path;
import java.nio.file.Paths;
import java.util.ArrayList;
import java.util.List;
import java.util.regex.Matcher;
import java.util.regex.Pattern;

public class Release {
    static final Path GRADLEW;

    static {
        if (os() == OS.Windows) {
            GRADLEW = Paths.get("gradlew.bat");
        } else {
            GRADLEW = Paths.get("gradlew");
        }
    }

    public static void main(String[] args) {
        new Release().run();
    }

    void run() {
        try {
            // Get latest commit message
            String commit = exec(false, "git", "log", "HEAD^..HEAD", "--pretty=%B").out();
            List<ModuleRelease> modules = parseReleases(commit);
            if (modules.isEmpty()) {
                System.out.println("✅ No modules to release.");
                return;
            }

            modules.forEach(this::release);
            System.out.println("🎉 Release process completed.");
        } catch (Exception ex) {
            ex.printStackTrace();
        }
    }

    void release(ModuleRelease module) {
        try {
            System.out.println("🚀 Releasing module: " + module.module());
            exec(true, GRADLEW.toAbsolutePath().toString(), ":%s:publishAndReleaseToMavenCentral".formatted(module.module()));
        } catch (Exception ex) {
            System.err.println("❌ Failed to release module: " + module.module());
            ex.printStackTrace();
        }
    }

    List<ModuleRelease> parseReleases(String commit) {
        List<ModuleRelease> releases = new ArrayList<>();

        String[] modules = new String[] {
            "aio",
            "components",
            "core",
            "effects",
            "localization",
            "resources",
        };
        Pattern pt = Pattern.compile("\\d+(\\.\\d+)+");
        String[] lines = commit.split("\n");
        for (int i = 1; i < lines.length; i++) { // Skip header
            String line = lines[i];
            for (String module : modules) {
                if (!line.contains(module.trim())) continue;
                Matcher matcher = pt.matcher(line);
                if (!matcher.find())
                    throw new RuntimeException("Could not extract version for module: " + module);
                String ver = matcher.group(0);
                releases.add(new ModuleRelease(module.trim(), ver.trim()));

            }
        }
        return releases;
    }

    //================================================================================
    // Model
    //================================================================================

    enum OS {
        Windows, Linux, MacOS, Other
    }

    record ProcRet(
        int state, String out
    ) {}

    record ModuleRelease(
        String module,
        String version
    ) {}

    //================================================================================
    // Utilities
    //================================================================================
    ProcRet exec(boolean print, String... command) throws Exception {
        Process proc = new ProcessBuilder()
            .command(command)
            .redirectErrorStream(true)
            .start();

        // Consume the output stream in a separate thread
        StringBuilder sb = new StringBuilder();
        Thread outputThread = new Thread(() -> {
            try (BufferedReader reader = new BufferedReader(
                new InputStreamReader(proc.getInputStream()))) {
                String line;
                while ((line = reader.readLine()) != null) {
                    if (print) System.out.println(line);
                    sb.append(line).append("\n");
                }
            } catch (IOException e) {
                System.err.println(e.getMessage());
            }
        });
        outputThread.start();

        int ret = proc.waitFor();
        outputThread.join();
        return new ProcRet(ret, sb.toString());
    }

    static OS os() {
        String name = System.getProperty("os.name");
        return switch (name) {
            case String s when s.contains("win") || s.contains("Win") -> OS.Windows;
            case String s when s.contains("nix") || s.contains("nux") -> OS.Linux;
            case String s when s.contains("mac") || s.contains("Mac") -> OS.MacOS;
            default -> OS.Other;
        };
    }
}